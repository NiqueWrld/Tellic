{
  "name": "tellic",
  "productName": "Tellic",
  "version": "1.0.0",
  "description": "Tellic - archive chat transcripts from your Android device over ADB.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "build:icons": "node scripts/build-icons.mjs",
    "prestart": "npm run build:icons",
    "start": "electron-forge start",
    "prepackage": "powershell -ExecutionPolicy Bypass -File scripts/fetch-adb.ps1",
    "package": "electron-forge package",
    "premake": "npm run build:icons",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "fetch:adb": "powershell -ExecutionPolicy Bypass -File scripts/fetch-adb.ps1"
  },
  "keywords": [],
  "author": "USER PC",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-appx": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^2.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^42.0.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~4.5.5",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@phosphor-icons/web": "^2.1.2",
    "dotenv": "^17.4.2",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
